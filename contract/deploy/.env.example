# Cortex Protocol — Deploy Client Environment
# Copy to .env and fill in your values

# Required
STELLAR_SECRET_KEY=S...

# Network (testnet | mainnet | futurenet)
STELLAR_NETWORK=testnet

# RPC endpoints (defaults shown below)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# Retry configuration
MAX_RETRIES=5
RETRY_DELAY_MS=2000

# Max fee in stroops (1 XLM = 10_000_000 stroops)
MAX_FEE=1000000

# Monitoring: webhook URL for alerts (Discord/Slack/generic)
ALERT_WEBHOOK_URL=

# Debug mode (set to 1 for verbose error output)
DEBUG=
